<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Resume Analyzer AI</title>
    <style>
        :root {
            --primary: #2563eb;
            --bg: #f8fafc;
            --card: #ffffff;
            --text: #1e293b;
            --border: #e2e8f0;
            --success: #16a34a;
            --danger: #dc2626;
        }

        body {
            font-family: 'Inter', -apple-system, system-ui, sans-serif;
            background-color: var(--bg);
            color: var(--text);
            margin: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .container {
            background: var(--card);
            padding: 2.5rem;
            border-radius: 12px;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
            width: 100%;
            max-width: 450px;
            box-sizing: border-box;
        }

        section { display: none; } /* Hidden by default */
        section.active { display: block; }

        h2 { margin-top: 0; text-align: center; color: var(--primary); }
        p { text-align: center; color: #64748b; }

        input, button {
            width: 100%;
            padding: 0.8rem;
            margin: 0.6rem 0;
            border-radius: 6px;
            border: 1px solid var(--border);
            font-size: 1rem;
            box-sizing: border-box;
        }

        button {
            background-color: var(--primary);
            color: white;
            font-weight: 600;
            cursor: pointer;
            border: none;
            transition: transform 0.1s, opacity 0.2s;
        }

        button:hover { opacity: 0.9; }
        button:active { transform: scale(0.98); }

        .secondary { background-color: #64748b; }
        .danger { background-color: var(--danger); }
        .outline { background: transparent; border: 1px solid var(--primary); color: var(--primary); }

        ul { list-style: none; padding: 0; margin: 1.5rem 0; }
        li {
            background: #f1f5f9;
            padding: 12px;
            margin-bottom: 10px;
            border-radius: 8px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.9rem;
        }

        .actions { display: flex; gap: 5px; }
        .actions button { padding: 5px 10px; font-size: 0.8rem; margin: 0; width: auto; }

        .result-card {
            background: #eff6ff;
            border: 1px solid #bfdbfe;
            padding: 1.2rem;
            border-radius: 8px;
            margin-top: 1rem;
        }

        #loadingOverlay {
            display: none;
            color: var(--primary);
            font-weight: bold;
            margin: 10px 0;
            text-align: center;
        }
    </style>
</head>
<body>

<div class="container">
    <div id="loadingOverlay">Processing...</div>

    <!-- 1. LOGIN PAGE -->
    <section id="page-login" class="active">
        <h2>Resume AI</h2>
        <p>Sign in to analyze resumes</p>
        <form id="loginForm">
            <input type="email" id="login-email" placeholder="Email" required>
            <input type="password" id="login-pass" placeholder="Password" required>
            <button type="submit">Login</button>
        </form>
    </section>

    <!-- 2. DASHBOARD -->
    <section id="page-dashboard">
        <h2>Dashboard</h2>
        <div class="nav-links">
            <button onclick="showPage('page-upload')">Upload New Resume</button>
            <button class="outline" onclick="loadResumes()">View All Resumes</button>
            <button class="danger" onclick="logout()">Logout</button>
        </div>
    </section>

    <!-- 3. UPLOAD PAGE -->
    <section id="page-upload">
        <h2>Upload Resume</h2>
        <form id="uploadForm">
            <input type="file" id="resumeFile" accept=".pdf,.docx" required>
            <button type="submit">Start Upload</button>
            <button type="button" class="secondary" onclick="showPage('page-dashboard')">Cancel</button>
        </form>
    </section>

    <!-- 4. RESUME LIST -->
    <section id="page-list">
        <h2>Your Resumes</h2>
        <ul id="resumeList"></ul>
        <button class="secondary" onclick="showPage('page-dashboard')">Back</button>
    </section>

    <!-- 5. ANALYSIS PAGE -->
    <section id="page-analysis">
        <h2>Analysis Result</h2>
        <div id="analysisResult"></div>
        <br>
        <button class="secondary" onclick="showPage('page-list')">Back to List</button>
    </section>
</div>

<script>
    const BASE_URL = "http://localhost:8081";
    const loading = document.getElementById('loadingOverlay');

    // --- AUTH UI UTILS ---
    function showPage(pageId) {
        document.querySelectorAll('section').forEach(s => s.classList.remove('active'));
        document.getElementById(pageId).classList.add('active');

        // Check auth on every page change except login
        if (pageId !== 'page-login' && !localStorage.getItem("token")) {
            showPage('page-login');
        }
    }

    function toggleLoading(show) {
        loading.style.display = show ? 'block' : 'none';
    }

    function getAuthHeaders() {
        return {
            "Authorization": `Bearer ${localStorage.getItem("token")}`
        };
    }

    // --- 1. LOGIN ---
    document.getElementById('loginForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        toggleLoading(true);

        const email = document.getElementById('login-email').value;
        const password = document.getElementById('login-pass').value;

        try {
            const res = await fetch(`${BASE_URL}/api/auth/login`, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ email, password })
            });
            const data = await res.json();

            if (res.ok) {
                localStorage.setItem("token", data.token);
                showPage('page-dashboard');
            } else {
                alert(data.message || "Invalid credentials");
            }
        } catch (err) {
            alert("API Error: Is the server running?");
        } finally {
            toggleLoading(false);
        }
    });

    // --- 2. LOGOUT ---
    function logout() {
        localStorage.removeItem("token");
        showPage('page-login');
    }

    // --- 3. UPLOAD ---
    document.getElementById('uploadForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        toggleLoading(true);

        const fileInput = document.getElementById("resumeFile");
        const formData = new FormData();
        formData.append("file", fileInput.files[0]);

        try {
            const res = await fetch(`${BASE_URL}/api/resumes/upload`, {
                method: "POST",
                headers: getAuthHeaders(),
                body: formData
            });

            if (res.ok) {
                alert("Upload Successful!");
                loadResumes();
            } else {
                alert("Upload failed.");
            }
        } catch (err) {
            alert("Network error.");
        } finally {
            toggleLoading(false);
        }
    });

    // --- 4. LIST RESUMES ---
    async function loadResumes() {
        toggleLoading(true);
        showPage('page-list');
        const listEl = document.getElementById("resumeList");
        listEl.innerHTML = "";

        try {
            const res = await fetch(`${BASE_URL}/api/resumes/names`, { headers: getAuthHeaders() });
            const data = await res.json();

            if (data.length === 0) listEl.innerHTML = "<li>No resumes found.</li>";

            data.forEach(resume => {
                const li = document.createElement('li');
                li.innerHTML = `
                    <span>${resume.name}</span>
                    <div class="actions">
                        <button onclick="analyzeResume('${resume.id}')">Analyze</button>
                        <button class="danger" onclick="deleteResume('${resume.id}')">Delete</button>
                    </div>
                `;
                listEl.appendChild(li);
            });
        } catch (err) {
            alert("Failed to fetch resumes.");
        } finally {
            toggleLoading(false);
        }
    }

    // --- 5. ANALYZE ---
    async function analyzeResume(id) {
        toggleLoading(true);
        showPage('page-analysis');
        const resultArea = document.getElementById('analysisResult');
        resultArea.innerHTML = "Processing AI analysis...";

        try {
            const res = await fetch(`${BASE_URL}/api/analysis/resume/${id}`, {
                method: "POST",
                headers: getAuthHeaders()
            });
            const data = await res.json();

            resultArea.innerHTML = `
                <div class="result-card">
                    <h3 style="margin-top:0">Score: ${data.matchPercentage || 0}%</h3>
                    <p style="text-align:left"><strong>Skills:</strong> ${data.skills ? data.skills.join(', ') : 'N/A'}</p>
                    <p style="text-align:left"><strong>Suggestions:</strong> ${data.suggestions || 'None'}</p>
                </div>
            `;
        } catch (err) {
            resultArea.innerHTML = "Analysis failed. Please try again.";
        } finally {
            toggleLoading(false);
        }
    }

    // Init: Check if already logged in
    window.onload = () => {
        if (localStorage.getItem("token")) {
            showPage('page-dashboard');
        }
    };
</script>
</body>
</html>